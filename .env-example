# ──────────────────────────────────────────────────────────────────────
# Agentic-AFL Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control (it's in .gitignore).
# ──────────────────────────────────────────────────────────────────────

# ── LLM API Keys ─────────────────────────────────────────────────────
# At least one provider key is required for Z3 translation.
# Set LLM_API_PROVIDER to select which backend to use.

LLM_API_PROVIDER=gemini 
LLM_API_KEY=
GEMINI_API_KEY=
LLM_MODEL_NAME=gemini-3.1-pro-preview

# ── PostgreSQL ───────────────────────────────────────────────────────
# Connection string for the spec store.
# Default matches docker-compose.yml credentials.
POSTGRES_DSN=postgresql://agentic_afl:agentic_afl@localhost:5432/agentic_afl

# ── Ghidra ───────────────────────────────────────────────────────────
GHIDRA_INSTALL_DIR=/opt/ghidra
GHIDRA_PROJECT_DIR=/tmp/ghidra_projects

# ── Z3 Sandbox ───────────────────────────────────────────────────────
Z3_TIMEOUT_SECONDS=30
Z3_SANDBOX_DIR=/tmp/agentic_afl_sandbox

# ── AFL++ ────────────────────────────────────────────────────────────
AFL_OUTPUT_DIR=./afl_output
AFL_SYNC_DIR=./afl_output/sync_dir

# ── Orchestrator Tuning ──────────────────────────────────────────────
K_VOTE_COUNT=3                       # LINC §2: parallel Z3 scripts
LOG_LEVEL=INFO
